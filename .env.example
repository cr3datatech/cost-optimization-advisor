# AWS profile from ~/.aws/config (used for local runs and deploy)
AWS_PROFILE=your-aws-profile

AWS_BILLING_BUCKET=your-billing-bucket-name
AWS_REGION=eu-west-1
OPENAI_API_KEY=sk-...
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Deploy settings (scripts/manage.py)
LAMBDA_FUNCTION_NAME=cost-optimization-advisor
LAMBDA_ROLE_NAME=cost-advisor-lambda-role
LAMBDA_ROLE_ARN=arn:aws:iam::ACCOUNT_ID:role/cost-advisor-lambda-role
LAMBDA_RUNTIME=python3.12
# Optional: path to a pre-built Lambda zip that already includes dependencies
# LAMBDA_PACKAGE_PATH=dist/lambda-full.zip
